CORS_ALLOWED_ORIGINS=https://portal.demoopwr.in,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
QUARANTINE_DATA_FILE=./data/quarantine_messages.json

MAGIC_LINK_EXPIRE_MINUTES=1440
MAGIC_LINK_RATE_LIMIT_COUNT=3
MAGIC_LINK_RATE_LIMIT_WINDOW_MINUTES=15
MAGIC_SESSION_EXPIRE_MINUTES=1440
FRONTEND_MAGIC_LINK_URL=https://portal.demoopwr.in/?token=
REQUIRE_MAGIC_AUTH=true

# Public Cloudflare/HTTPS demo should keep this true.
# For direct local HTTP testing, set SESSION_COOKIE_SECURE=false.
SESSION_COOKIE_NAME=quarantine_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

JSON_WRITE_RETRY_COUNT=5
JSON_WRITE_RETRY_DELAY_SECONDS=0.08


