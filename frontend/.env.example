VITE_QUARANTINE_API_BASES=https://api.demoopwr.in/api/v1/quarantine

# Production/demo through Cloudflare Tunnel:
# VITE_QUARANTINE_API_BASES=https://api.demoopwr.in/api/v1/quarantine

# Local-only fallback while developing directly on the machine:
# VITE_QUARANTINE_API_BASES=http://localhost:8000/api/v1/quarantine,http://192.168.1.7:8000/api/v1/quarantine

# Single URL is also supported if you do not want fallback:
# VITE_QUARANTINE_API_BASE=https://api.demoopwr.in/api/v1/quarantine
